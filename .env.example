APP_NAME=Headline Under The Hood
DATABASE_PATH=data/app.db
STORAGE_ROOT=data/storage
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_TASK_QUEUE=financial-report-analysis
USE_TEMPORAL=true
# Gemini (Google AI) — get a key at https://aistudio.google.com/apikey
# Leave blank to run with deterministic-only analysis (no LLM augmentation).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
